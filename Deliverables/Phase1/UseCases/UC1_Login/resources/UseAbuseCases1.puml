@startuml
left to right direction
skinparam linetype ortho
skinparam shadowing false
skinparam backgroundColor #F9F9F9

skinparam usecase {
  BackgroundColor White
  BorderColor Black
  FontColor Black
}
skinparam usecase {
  BackgroundColor<<Threat>> Black
  FontColor<<Threat>> White
  BorderColor<<Threat>> Black
}
skinparam usecase {
  BackgroundColor<<Mitigation>> #34C759
  FontColor<<Mitigation>> White
  BorderColor<<Mitigation>> #248A3D
}
skinparam usecase {
  BackgroundColor<<External>> #5AC8FA
  FontColor<<External>> White
  BorderColor<<External>> #3A99D9
}
skinparam usecase {
  BackgroundColor<<Vulnerability>> #B0B0B0
  FontColor<<Vulnerability>> Black
  BorderColor<<Vulnerability>> #808080
}

actor User
actor Attacker #red

rectangle "Login Flow" {
  User --> (Login to app)
  (Login to app) --> (Redirect to Auth0 login page)
  (Redirect to Auth0 login page) --> (Submit credentials on Auth0) <<External>>
  (Submit credentials on Auth0) --> (Auth0 validates credentials) <<External>>
  (Auth0 validates credentials) --> (Auth0 returns authorization code) <<External>>
  (Auth0 returns authorization code) --> (Exchange code + code_verifier for JWT) <<External>>
  (Exchange code + code_verifier for JWT) --> (Auth0 issues JWT) <<External>>
  (Auth0 issues JWT) --> (Return JWT to client) <<Mitigation>>
}

' --- VULNERABILITIES
(Submit credentials on Auth0) <<Vulnerability>>
(Return JWT to client) <<Vulnerability>>
(Auth0 returns authorization code) <<Vulnerability>>

' --- THREATS
(Brute-force attack) <<Threat>>
(Network sniffing) <<Threat>>
(Intercept credentials) <<Threat>>
(Authorization code interception) <<Threat>>
(Token replay attack) <<Threat>>

' --- THREAT CONNECTIONS
(Submit credentials on Auth0) <-- (Brute-force attack) #red : <<Threatens>>
(Submit credentials on Auth0) <-- (Intercept credentials) #red : <<Threatens>>
(Intercept credentials) <-- (Network sniffing) <<Threat>>
(Network sniffing) <-- Attacker
(Brute-force attack) <-- Attacker
(Auth0 returns authorization code) <-- (Authorization code interception) #red : <<Threatens>>
(Authorization code interception) <-- Attacker
(Return JWT to client) <-- (Token replay attack) #red : <<Threatens>>
(Token replay attack) <-- Attacker

' --- MITIGATIONS
(Submit credentials on Auth0) --> (Enforce rate limit + lockout) <<Mitigation>>
(Intercept credentials) --> (Use TLS / HTTPS) <<Mitigation>>
(Authorization code interception) --> (PKCE code_verifier validation) <<Mitigation>>
(Token replay attack) --> (Short token expiry + rotation) <<Mitigation>>

' --- MITIGATES ARROWS
(Enforce rate limit + lockout) --> (Brute-force attack) #green : <<Mitigates>>
(Use TLS / HTTPS) --> (Intercept credentials) #green : <<Mitigates>>
(PKCE code_verifier validation) --> (Authorization code interception) #green : <<Mitigates>>
(Short token expiry + rotation) --> (Token replay attack) #green : <<Mitigates>>

@enduml