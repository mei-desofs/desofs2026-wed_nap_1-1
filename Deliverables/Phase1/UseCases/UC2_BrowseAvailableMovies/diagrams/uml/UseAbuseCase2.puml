@startuml
left to right direction
skinparam linetype ortho
skinparam shadowing false
skinparam backgroundColor #F9F9F9

skinparam usecase {
  BackgroundColor White
  BorderColor Black
  FontColor Black
}

skinparam usecase {
  BackgroundColor<<Threat>> #FF3B30
  FontColor<<Threat>> White
  BorderColor<<Threat>> #C1271C
}

skinparam usecase {
  BackgroundColor<<Mitigation>> #34C759
  FontColor<<Mitigation>> White
  BorderColor<<Mitigation>> #248A3D
}

actor Customer
actor Attacker #red

rectangle "View Movies Flow" {
  Customer --> (View available movies)

  ' --- Normal Flow
  (View available movies) --> (Send movie list request)
  (Send movies list request) --> (Backend fetches from DB)
  (Backend fetches from DB) --> (Return movie list to API client)
}

' --- Threats
(Send movie list request) ---> (Movie catalog scraping) #red : <<Threatens>>
(Send movie list request) --> (Request tampering - filter bypass) #red : <<Threatens>>
(Backend fetches from DB) --> (Access to unreleased/hidden movies) #red : <<Threatens>>
(View available movies) --> (Massive concurrent requests / DoS) #red : <<Threatens>>

(Movie catalog scraping) --> Attacker
(Request tampering - filter bypass) --> Attacker
(Access to unreleased/hidden movies) --> Attacker
(Massive concurrent requests / DoS) --> Attacker

' --- Mitigations
(Movie catalog scraping) --> (Bot detection / rate limiting) #green : <<Mitigates>>
(Request tampering - filter bypass) --> (Validate query params + RBAC) #green : <<Mitigates>>
(Access to unreleased/hidden movies) ---> (Enforce release flags + ACLs) #green : <<Mitigates>>
(Massive concurrent requests / DoS) --> (API throttling / CDN caching) #green : <<Mitigates>>

' --- External Factors
(View available movies) --> (External DDOS attack) <<External>> : <<Affected by>>
(Backend fetches from DB) --> (Database injection vulnerability) <<External>> : <<Affected by>>

' --- VULNERABILITIES
(Send movie list request) <<Vulnerability>>
(Backend fetches from DB) <<Vulnerability>>
(Massive concurrent requests / DoS) <<Vulnerability>>
(Request tampering - filter bypass) <<Vulnerability>>

' --- THREATS
(Movie catalog scraping) <<Threat>>
(Request tampering - filter bypass) <<Threat>>
(Access to unreleased/hidden movies) <<Threat>>
(Massive concurrent requests / DoS) <<Threat>>

@enduml