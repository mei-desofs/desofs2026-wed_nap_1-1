@startuml
title eMovieShop - View Requested Refunds

actor Support
participant "API Client" as APIClient
participant "RefundController" as RefundController
participant "RefundService" as RefundService
participant "RefundRepository" as RefundRepository

activate Support
Support -> APIClient : GET /refunds {userId}
activate APIClient
APIClient -> RefundController : getRefunds(userId)
activate RefundController
RefundController -> RefundService : fetchRefunds(userId)
activate RefundService
RefundService -> RefundRepository : findRefundsByUserId(userId)
activate RefundRepository
RefundRepository --> RefundService : List of refunds
deactivate RefundRepository

RefundService --> RefundController : Refunds data
deactivate RefundService
RefundController --> APIClient : 200 OK + refunds data
deactivate RefundController
APIClient --> Support : JSON response (refunds data)
deactivate APIClient
deactivate Support
@enduml
