                  "// Decode JWT sub claim and use it as the target user id",
                  "const token = pm.environment.get('ACCESS_TOKEN');",
                  "if (token) {",
                  "    const parts = token.split('.');",
                  "    if (parts.length === 3) {",
                  "        const payload = JSON.parse(atob(parts[1].replace(/-/g, '+').replace(/_/g, '/')));",
                  "        pm.variables.set('SELF_USER_ID', payload.sub);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
