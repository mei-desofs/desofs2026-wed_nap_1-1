    {
      "name": "UC2 - Browse Available Movies",
      "item": [
        {
          "name": "List movies (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('Body is an array', function () { pm.expect(body).to.be.an('array'); });",
                  "if (Array.isArray(body) && body.length > 0 && body[0].id) {",
                  "    pm.environment.set('MOVIE_ID', body[0].id);",
                  "    console.log('MOVIE_ID set to ' + body[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ACCESS_TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/movies",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "api",
                "movies"
              ]
            },
            "description": "Lists the catalog. Any authenticated user. Auto-saves the first movie id into MOVIE_ID."
